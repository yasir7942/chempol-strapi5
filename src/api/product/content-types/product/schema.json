{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "product_categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product-category.product-category",
      "inversedBy": "products"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "seo.seo-infomation",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "productImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "description": {
      "type": "blocks",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "related_products": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product",
      "mappedBy": "product"
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "related_products"
    },
    "application": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "tdsPacking": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "productSchema": {
      "type": "component",
      "repeatable": false,
      "component": "seo.product-schema",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "TDSFile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "files"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "MSDSFile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "files"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "table": {
      "type": "component",
      "repeatable": true,
      "component": "layout.product-table",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "faq": {
      "type": "component",
      "repeatable": true,
      "component": "layout.faq",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "api": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::api.api",
      "inversedBy": "products"
    },
    "ssis": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::ssi.ssi",
      "mappedBy": "product"
    },
    "sys_aceas": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::acea.acea",
      "mappedBy": "product"
    },
    "sys_ilsacs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::ilsac.ilsac",
      "mappedBy": "product"
    },
    "sys_oems": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::oem.oem",
      "mappedBy": "product"
    },
    "sys_jasos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::jaso.jaso",
      "mappedBy": "product"
    },
    "Dosage": {
      "type": "component",
      "repeatable": true,
      "component": "layout.dosage-table"
    },
    "sae_grades": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::sae-grade.sae-grade",
      "inversedBy": "products"
    },
    "types": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::type.type",
      "inversedBy": "products"
    },
    "dosages": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::dosage.dosage",
      "mappedBy": "products"
    }
  }
}
